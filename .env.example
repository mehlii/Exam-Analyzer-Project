# Bu dosyayı .env olarak kopyala ve değerleri doldur:
#   cp .env.example .env
# .env dosyası git'e commit edilmez (.gitignore'da).

# Demo modu — VARSAYILAN OLARAK AÇIK.
# Aktifken upload edilen her dosya için sabit Beril Yıldız LGS karnesi gösterilir.
# Sunum sırasında AI ya da pipeline çalışmasa bile garantili güzel sonuç için.
# 1=aktif (varsayılan), 0=kapalı.
DEMO_MODE=1

# Google AI Studio'dan API key (opsiyonel — sadece DEMO_MODE=0 ise gerekli):
# https://aistudio.google.com/app/apikey
# Görsel/JPEG/PNG sınav belgesi yüklemek ve gerçek AI yorum almak için.
GEMINI_API_KEY=
